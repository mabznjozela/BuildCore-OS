rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // All documents require an authenticated user. Kitchen Lab OS is an
    // internal workshop tool; there is no public read surface. Tighten
    // further per-collection once user roles / ownership are added.
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
